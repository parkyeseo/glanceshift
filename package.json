{
  "name": "glanceshift",
  "version": "0.0.1",
  "description": "Tobii Eye Tracker 5 pilot experiment for gaze and head-pose interruption control",
  "main": "./out/main/index.js",
  "author": "GlanceShift Team",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:tobii": "powershell -ExecutionPolicy Bypass -File tools/tobii-bridge/build.ps1",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "loudness": "^0.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
